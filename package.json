{
  "name": "driftx",
  "version": "0.1.3",
  "description": "Visual diff tool for mobile development — Android, iOS, and React Native",
  "type": "module",
  "main": "./dist/bin.js",
  "bin": {
    "driftx": "./dist/bin.js"
  },
  "files": [
    "dist",
    "driftx-plugin",
    "ios-companion"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:device": "DRIFTX_DEVICE_TESTS=1 vitest run test/device/",
    "lint": "tsc --noEmit",
    "build:ios": "bash scripts/build-ios-companion.sh",
    "prepublishOnly": "bash scripts/verify-prebuilt.sh"
  },
  "keywords": [
    "react-native",
    "android",
    "ios",
    "mobile",
    "visual-diff",
    "accessibility",
    "screenshot",
    "testing"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nomanr/driftx.git"
  },
  "homepage": "https://driftx.nomanr.com",
  "bugs": {
    "url": "https://github.com/nomanr/driftx/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "nanoid": "^5.1.6",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
